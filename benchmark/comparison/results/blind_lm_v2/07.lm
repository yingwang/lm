fn fib(n: Int) -> Int {
    if n <= 0 { 0 }
    else if n == 1 { 1 }
    else { fib(n - 1) + fib(n - 2) }
}

io fn main() -> Unit {
    let _ = print(to_string(fib(0)));
    let _ = print(to_string(fib(1)));
    let _ = print(to_string(fib(2)));
    let _ = print(to_string(fib(5)));
    print(to_string(fib(10)))
}

let _ = main();
