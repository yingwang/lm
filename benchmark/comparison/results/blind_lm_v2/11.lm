fn collatz_steps(n: Int) -> Int {
    if n <= 1 { 0 }
    else {
        let r = n - (n / 2) * 2;
        if r == 0 { 1 + collatz_steps(n / 2) }
        else { 1 + collatz_steps(3 * n + 1) }
    }
}

io fn main() -> Unit {
    let _ = print(to_string(collatz_steps(1)));
    let _ = print(to_string(collatz_steps(2)));
    let _ = print(to_string(collatz_steps(6)));
    print(to_string(collatz_steps(10)))
}

let _ = main();
