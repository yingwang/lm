fn format_greeting(name: String, age: Int) -> String {
    "Hello, " ++ name ++ "! You are " ++ int_to_string(age) ++ " years old."
}

io fn print_greeting(name: String, age: Int) -> Unit {
    print(format_greeting(name, age))
}

io fn main() -> Unit {
    let _ = print_greeting("Alice", 30);
    print_greeting("Bob", 25)
}

let _ = main();
