fn unwrap_or(opt: Option<Int>, default: Int) -> Int {
    match opt {
        Some(v) -> v,
        None -> default,
    }
}

io fn main() -> Unit {
    let _ = print(int_to_string(unwrap_or(Some(42), 0)));
    let _ = print(int_to_string(unwrap_or(None, 0)));
    let _ = print(int_to_string(unwrap_or(Some(-1), 99)));
    print(int_to_string(unwrap_or(None, -1)))
}

let _ = main();
