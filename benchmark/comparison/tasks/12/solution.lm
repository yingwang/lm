fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { 1 }
    else { base * power(base, exp - 1) }
}

let _ = print(to_string(power(2, 0)));
let _ = print(to_string(power(2, 10)));
let _ = print(to_string(power(3, 4)));
let _ = print(to_string(power(5, 3)));
let _ = print(to_string(power(1, 100)));
