fn palindrome_check(s: String, lo: Int, hi: Int) -> Bool {
    if lo >= hi { true }
    else if char_at(s, lo) != char_at(s, hi) { false }
    else { palindrome_check(s, lo + 1, hi - 1) }
}

fn is_palindrome(s: String) -> Bool {
    palindrome_check(s, 0, str_len(s) - 1)
}

let _ = print(to_string(is_palindrome("racecar")));
let _ = print(to_string(is_palindrome("hello")));
let _ = print(to_string(is_palindrome("")));
let _ = print(to_string(is_palindrome("a")));
