type Expr =
    | Lit(Int)
    | Add(Int, Int)
    | Mul(Int, Int)

fn eval(e: Expr) -> Int {
    match e {
        Lit(n) -> n,
        Add(a, b) -> a + b,
        Mul(a, b) -> a * b,
    }
}

fn describe(e: Expr) -> String {
    match e {
        Lit(n) -> to_string(n),
        Add(a, b) -> to_string(a) ++ " + " ++ to_string(b),
        Mul(a, b) -> to_string(a) ++ " * " ++ to_string(b),
    }
}
