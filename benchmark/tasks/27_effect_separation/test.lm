fn mod_int(a: Int, b: Int) -> Int {
    a - (a / b) * b
}

fn fizzbuzz(n: Int) -> String {
    let by3 = mod_int(n, 3) == 0;
    let by5 = mod_int(n, 5) == 0;
    if by3 && by5 { "FizzBuzz" }
    else if by3 { "Fizz" }
    else if by5 { "Buzz" }
    else { to_string(n) }
}

let _ = print(fizzbuzz(1));
let _ = print(fizzbuzz(3));
let _ = print(fizzbuzz(5));
let _ = print(fizzbuzz(15));
let _ = print(fizzbuzz(7));
