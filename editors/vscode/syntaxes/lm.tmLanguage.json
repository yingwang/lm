{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LM",
  "scopeName": "source.lm",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.lm",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lm",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lm",
              "match": "\\\\[nrt\\\\\"0]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.lm",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.lm",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lm",
          "match": "\\b(if|else|match)\\b"
        },
        {
          "name": "keyword.declaration.lm",
          "match": "\\b(fn|let|type)\\b"
        },
        {
          "name": "keyword.effect.lm",
          "match": "\\b(io|pure)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.lm",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.lm",
          "match": "\\b(None)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.lm",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.lm",
          "match": "->"
        },
        {
          "name": "keyword.operator.concat.lm",
          "match": "\\+\\+"
        },
        {
          "name": "keyword.operator.comparison.lm",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.lm",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.arithmetic.lm",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.assignment.lm",
          "match": "="
        },
        {
          "name": "keyword.operator.pipe.lm",
          "match": "\\|"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.lm",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.lm",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
