{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run LM",
      "type": "shell",
      "command": "${workspaceFolder}/target/release/lmc",
      "args": ["run", "${file}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
